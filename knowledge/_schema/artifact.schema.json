{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Punk Knowledge Artifact",
  "type": "object",
  "required": [
    "id",
    "title",
    "kind",
    "status",
    "authority",
    "owner",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "kind": {
      "enum": [
        "product",
        "architecture",
        "decision",
        "research",
        "experiment",
        "ops",
        "idea",
        "code"
      ]
    },
    "status": {
      "enum": [
        "raw",
        "draft",
        "accepted",
        "superseded",
        "deprecated",
        "archived"
      ]
    },
    "authority": {
      "enum": [
        "canonical",
        "advisory",
        "speculative"
      ]
    },
    "owner": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "review_after": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
