---
import SectionHeader from './SectionHeader.astro';
import { lifecycleSteps } from '../data/content';
---

<section class="section" id="how">
  <div class="wrap">
    <SectionHeader
      n="03"
      kicker="lifecycle"
      sub="Every piece of work travels the same path. When it closes, the project's memory is a little longer and a little more honest."
    >
      <Fragment slot="title">One loop. Seven artifacts.</Fragment>
    </SectionHeader>

    <div class="howDiagram">
      <div class="howMeta">
        <span>∎ work.flow.v0</span>
        <span>loop closes → memory grows</span>
      </div>

      <div class="howRail">
        <svg class="howRailLine" width="100%" height="2" aria-hidden="true">
          <line x1="6%" y1="1" x2="94%" y2="1" stroke="#ff2e88" stroke-width="1" stroke-dasharray="4 4" opacity="0.4"></line>
        </svg>
        {lifecycleSteps.map((step, index) => (
          <div class="howNode">
            <div class={`howNodeIndex howNodeIndex--${step.tone}`}>{String(index + 1).padStart(2, '0')}</div>
            <div class="howNodeName">{step.key}</div>
            <div class="howNodeSub">{step.subtitle}</div>
            {index < lifecycleSteps.length - 1 && <div class="howArrow">→</div>}
          </div>
        ))}
      </div>

      <div class="howLoopback">
        <svg width="100%" height="50" viewBox="0 0 1000 50" preserveAspectRatio="none" aria-hidden="true">
          <path d="M 940 0 C 940 40, 940 46, 500 46 C 60 46, 60 40, 60 0" stroke="#ff48a1" stroke-width="1.2" stroke-dasharray="3 4" fill="none" opacity="0.75"></path>
          <polygon points="60,0 54,12 66,12" fill="#ff48a1"></polygon>
        </svg>
        <div class="howLoopLabel">next run reads the memory</div>
      </div>
    </div>

    <div class="howReceipts">
      <div class="receipt">
        <div><span class="receiptAccent">// receipt.0x8a2f</span></div>
        <div><span class="receiptKey">spec:</span> <span class="receiptValue">goals/payments-auth.md@a4c1</span></div>
        <div><span class="receiptKey">seed:</span> <span class="receiptValue">0x00e7…3b</span></div>
        <div><span class="receiptKey">agents:</span> <span class="receiptValue">2</span> · <span class="receiptKey">tool_calls:</span> <span class="receiptValue">18</span></div>
        <div><span class="receiptKey">budget:</span> <span class="receiptValue">$0.42 / $5.00</span></div>
        <div><span class="receiptKey">diff:</span> <span class="receiptValue">+182 −94 · sha256:ff…91</span></div>
        <div><span class="receiptKey">gate:</span> <span class="receiptOk">14/14 ✓</span></div>
        <div><span class="receiptKey">status:</span> <span class="receiptOk">accepted</span> · <span class="receiptKey">by</span> <span class="receiptAccent">@mira</span></div>
      </div>
      <div class="receipt">
        <div><span class="receiptAccent">// contract.lock</span></div>
        <div><span class="receiptKey">hash:</span> <span class="receiptValue">sha256:c2…9a</span></div>
        <div><span class="receiptKey">grants:</span></div>
        <div>&nbsp;&nbsp;<span class="receiptValue">fs:rw</span> on src/auth/**</div>
        <div>&nbsp;&nbsp;<span class="receiptValue">fs:ro</span> on docs/**</div>
        <div>&nbsp;&nbsp;<span class="receiptWarn">no-net</span></div>
        <div><span class="receiptKey">checks:</span> <span class="receiptValue">tests/auth/** · p99 &lt; 180ms · 0 new 401s</span></div>
        <div><span class="receiptKey">budget:</span> <span class="receiptValue">$5.00 hard cap</span></div>
        <div><span class="receiptKey">signed:</span> <span class="receiptAccent">@mira</span> · 2026-04-18T14:02Z</div>
      </div>
    </div>
  </div>
</section>

<style>
  .howDiagram {
    position: relative;
    margin-bottom: 32px;
    padding: 48px 32px 40px;
    border: 1px solid var(--border);
    background: radial-gradient(ellipse at 50% 50%, #0a0912 0%, #05040a 80%);
  }

  .howMeta {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 28px;
    color: #3a3848;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .howRail {
    position: relative;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0;
  }

  .howRailLine {
    position: absolute;
    top: 42px;
    left: 0;
  }

  .howNode {
    position: relative;
    padding: 0 6px;
    text-align: center;
  }

  .howNodeIndex {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    margin: 0 auto 14px;
    border: 1.5px solid var(--fg-3);
    background: #05040a;
    color: var(--fg-3);
    box-shadow: 0 0 0 4px #05040a;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .howNodeIndex--accent {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 0 4px #05040a, 0 0 24px rgba(255, 46, 136, 0.13);
  }

  .howNodeIndex--warn {
    border-color: var(--warn);
    color: var(--warn);
    box-shadow: 0 0 0 4px #05040a, 0 0 24px rgba(255, 192, 107, 0.12);
  }

  .howNodeIndex--success {
    border-color: var(--success);
    color: var(--success);
    box-shadow: 0 0 0 4px #05040a, 0 0 24px rgba(63, 227, 141, 0.13);
  }

  .howNodeIndex--info {
    border-color: var(--info);
    color: var(--info);
    box-shadow: 0 0 0 4px #05040a, 0 0 24px rgba(119, 169, 255, 0.13);
  }

  .howNodeIndex--soft {
    border-color: var(--fg-2);
    color: var(--fg-2);
    box-shadow: 0 0 0 4px #05040a, 0 0 24px rgba(166, 163, 150, 0.1);
  }

  .howNodeName {
    margin-bottom: 4px;
    color: var(--fg);
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .howNodeSub {
    min-height: 28px;
    color: var(--fg-3);
    font-family: var(--font-mono);
    font-size: 10.5px;
    line-height: 1.4;
    letter-spacing: 0.06em;
  }

  .howArrow {
    position: absolute;
    top: 24px;
    right: -6px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 14px;
    opacity: 0.8;
  }

  .howLoopback {
    position: relative;
    height: 50px;
    margin-top: 32px;
  }

  .howLoopLabel {
    position: absolute;
    bottom: -4px;
    left: 50%;
    padding: 0 12px;
    background: #05040a;
    color: var(--accent-bright);
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .howReceipts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  @media (max-width: 1100px) {
    .howRail {
      grid-template-columns: repeat(7, minmax(140px, 1fr));
      overflow-x: auto;
      padding-bottom: 10px;
    }
  }

  @media (max-width: 720px) {
    .howDiagram {
      padding: 32px 20px 28px;
    }

    .howMeta {
      flex-direction: column;
      gap: 10px;
    }

    .howReceipts {
      grid-template-columns: 1fr;
    }
  }
</style>
