---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'punk — a bounded work kernel for local work',
  description = 'A personal experimental, local-first bounded work kernel for researchers and experimenters. It may break at any time and is not guaranteed to work end-to-end.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="ink">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#05040a" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
