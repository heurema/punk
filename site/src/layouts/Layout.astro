---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'punk — a bounded work kernel for agents',
  description = 'A local-first work kernel for contract-tracked, eval-gated, proof-bearing AI work.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="ink">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05040a" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
